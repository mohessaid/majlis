# ── AMD droplet env vars ─────────────────────────────────────────────────────

# HuggingFace token (required for Llama-3.1)
HF_TOKEN=hf_...

# Tavily web search (sign up free at tavily.com)
TAVILY_API_KEY=tvly-...

# Clerk (backend secret key — from clerk.com dashboard)
CLERK_SECRET_KEY=sk_live_...

# Frontend origin for CORS (your Cloudflare Pages URL)
FRONTEND_ORIGIN=https://majlis.pages.dev

# ── Frontend (.env in frontend/) ─────────────────────────────────────────────

# Your droplet's public IP or domain
# VITE_API_URL=https://your-droplet-ip-or-domain

# Clerk publishable key (from clerk.com dashboard)
# VITE_CLERK_PUBLISHABLE_KEY=pk_live_...
